{
  "document_id": "BTP-001",
  "title": "BTL Measurement Protocol for HUF Calibration Rack",
  "version": "1.0",
  "date": "2026-03-19 18:57:12",
  "prepared_by": "Claude (Opus 4.6)",
  "directed_by": "Peter Higgins",
  "facility": "Rogue Wave Audio, Binaural Test Lab, Markham, Canada",
  "equipment": {
    "adc_dac": "4-channel (Ch1: loopback, Ch2-4: test mics)",
    "system": "BTL omnidirectional loudspeaker (H=0.8m, W=0.368m, D=0.33m)",
    "amplifier": "Lab.gruppen D10:4L with Lake DSP",
    "correction": "DADC-ADAC diffraction correction"
  },
  "test_sequence": {
    "phase_1_individual_drivers": {
      "purpose": "Build carrier simplex for T1c",
      "tests": [
        {
          "id": "T1",
          "condition": "woofer_only",
          "description": "Woofer(s) only, all others muted"
        },
        {
          "id": "T2",
          "condition": "mid_only",
          "description": "Midrange(s) only"
        },
        {
          "id": "T3",
          "condition": "tweet_only",
          "description": "Tweeter(s) only, HP filtered for protection"
        },
        {
          "id": "T4",
          "condition": "driver4_only",
          "description": "4th driver if exists (sub/super)"
        }
      ],
      "output": "Per-driver transfer functions \u2192 power share matrix \u03c1_driver(f)"
    },
    "phase_2_combined_system": {
      "purpose": "Shock detection (T3) and stability baseline (T2)",
      "tests": [
        {
          "id": "T5",
          "condition": "all_flat",
          "description": "All drivers, no crossover, no EQ"
        },
        {
          "id": "T6",
          "condition": "all_xover",
          "description": "All drivers, crossover engaged"
        },
        {
          "id": "T7",
          "condition": "all_corrected",
          "description": "All drivers, crossover + DADC-ADAC correction"
        }
      ],
      "output": "Three system states for structural intervention detection"
    },
    "phase_3_identity": {
      "purpose": "Identity sensitivity test (T4)",
      "tests": [
        {
          "id": "T8",
          "condition": "identity_test",
          "description": "Repeat T6 with one controlled physical change"
        }
      ],
      "output": "Paired comparison for identity blindness test"
    }
  },
  "file_convention": {
    "pattern": "BTL_{condition}_{mic}.txt",
    "mics": [
      "mic1 (LP on-axis)",
      "mic2 (off-axis)",
      "mic3 (near-field)"
    ],
    "format": "Frequency(Hz) TAB Magnitude(dB) TAB Phase(deg) [TAB Coherence]",
    "total_files": "24 measurement files + 1 notes file"
  },
  "calibration_rack_coverage": {
    "T1c_clear_carrier": "Tests 1-3(4) \u2192 carrier simplex",
    "T2_stable": "Test 6 vs historical versions",
    "T3_shock": "Tests 5-7 (flat\u2192xover\u2192corrected)",
    "T4_identity": "Test 8 vs Test 6",
    "projected_scorecard": "9/16 \u2192 13/16 after BTL suite"
  },
  "ember_data": {
    "url": "https://ember-energy.org/data/monthly-electricity-data/",
    "format": "Long format CSV",
    "coverage": "88 countries, monthly, generation by source",
    "license": "CC-BY-4.0",
    "tests_covered": [
      "T1 (clear carrier)",
      "T3 (known shocks: Fukushima, COVID, Ukraine)"
    ],
    "projected_scorecard": "13/16 \u2192 15/16 after EMBER"
  }
}