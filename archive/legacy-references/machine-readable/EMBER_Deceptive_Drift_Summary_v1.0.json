{
  "document_id": "EMBER-DRIFT-001",
  "title": "EMBER Monthly Electricity \u2014 Deceptive Drift Analysis for Forward Signal Triad",
  "version": "1.0",
  "date": "2026-03-22",
  "prepared_by": "Claude (Opus 4.6)",
  "directed_by": "Peter Higgins",
  "purpose": "Test whether deceptive drift (K_eff falling while TV stays calm) precedes known structural shocks in electricity generation, as the second domain in the forward signal triad (finance is domain 1).",
  "data_source": "EMBER Monthly Electricity Data (CC BY 4.0)",
  "methodology": {
    "carrier_construction": "Monthly electricity generation by fuel type (9 types) normalized to proportions summing to 1",
    "keff": "exp(Shannon entropy) of monthly fuel-type proportions",
    "tv": "L2 norm of proportion differences between consecutive months",
    "deceptive_drift_definition": "K_eff slope negative over 6-month window AND mean TV below series median in same window",
    "shock_test": "Check whether any deceptive drift regime occurs within 12 months before a known structural shock"
  },
