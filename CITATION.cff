    given-names: Peter
    email: peterhiggins2016@gmail.com
date-released: "2026-03-11"
version: "Phase 3"
repository-code: "https://github.com/peterhiggins/HUF"
license: "All Rights Reserved"
keywords:
  - ratio-state monitoring
  - unity constraint
  - compositional data
  - drift detection
  - MC-4
  - persistent homology
  - Ramsar
  - monitoring drift gain
